{
  "name": "flexweb",
  "version": "0.1.0",
  "description": "AI-powered Chrome extension for persistent website customization.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "format": "biome format --write .",
    "lint": "biome check .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:browser": "playwright test",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@playwright/test": "latest",
    "@types/chrome": "0.2.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "latest"
  }
}
